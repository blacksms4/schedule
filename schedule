import tkinter as tk
from tkinter import ttk, messagebox, simpledialog
import calendar
import random
from datetime import datetime
import holidays

# 근무 관리 엔진: 배정 결과가 저장되면 계속 유지됩니다.
class DutyEngine:
    def __init__(self):
        self.kr_holidays = holidays.KR()
        self.assignments = {}  # 한 달 동안 유지되는 배정 결과 저장소
        self.candidate_list = ["김철수", "이영희", "박지민", "최우주", "정다운"] 
        self.duty_count = 1 

    def is_duty_day(self, year, month, day):
        try:
            d = datetime(year, month, day)
            return d.weekday() >= 5 or d in self.kr_holidays
        except: 
            return False

# 근무자 관리 탭
class MemberTab(tk.Frame):
    def __init__(self, parent, engine, refresh_callback):
        super().__init__(parent)
        self.engine = engine
        self.refresh_callback = refresh_callback 
        
        tk.Label(self, text="근무자 명단 설정", font=("Arial", 12, "bold")).pack(pady=10)
        self.listbox = tk.Listbox(self, width=30, height=10)
        self.listbox.pack(pady=5)
        self.refresh_list()
        
        btn_frame = tk.Frame(self)
        btn_frame.pack(pady=10)
        tk.Button(btn_frame, text="순번 랜덤 섞기", command=self.shuffle_members).pack(side="left", padx=5)
        # 이번 달 자동 배정 (한번 누르면 고정)
        tk.Button(btn_frame, text="이번 달 자동 고정 배정", command=self.auto_assign, bg="#ff9f43").pack(side="left", padx=5)
        
    def refresh_list(self):
        self.listbox.delete(0, tk.END)
        for member in self.engine.candidate_list:
            self.listbox.insert(tk.END, member)
            
    def shuffle_members(self):
        random.shuffle(self.engine.candidate_list)
        self.refresh_list()

    def auto_assign(self):
        # 이미 배정된 일정이 있을 경우 덮어쓸지 확인
        if self.engine.assignments and not messagebox.askyesno("확인", "이미 배정된 일정이 있습니다. 다시 배정하시겠습니까?"):
            return
            
        self.engine.assignments = {}
        candidate_idx = 0
        num_candidates = len(self.engine.candidate_list)
        now = datetime.now()
        
        cal = calendar.Calendar(firstweekday=6).monthdatescalendar(now.year, now.month)
        for week in cal:
            for date_obj in week:
                if date_obj.month == now.month and self.engine.is_duty_day(now.year, now.month, date_obj.day):
                    names = [self.engine.candidate_list[(candidate_idx + i) % num_candidates] for i in range(self.engine.duty_count)]
                    self.engine.assignments[f"{now.year}-{now.month}-{date_obj.day}"] = ", ".join(names)
                    candidate_idx += self.engine.duty_count
        
        self.refresh_callback()
        messagebox.showinfo("알림", "이번 달 근무 배정이 완료되었습니다.")

# 달력 탭 모듈
class CalendarTab(tk.Frame):
    def __init__(self, parent, engine):
        super().__init__(parent)
        self.engine = engine
        now = datetime.now()
        self.year, self.month = now.year, now.month
        self.header_frame = tk.Frame(self)
        self.header_frame.pack(pady=10)
        self.cal_frame = tk.Frame(self)
        self.cal_frame.pack()
        self.refresh_calendar()

    def refresh_calendar(self):
        for widget in self.header_frame.winfo_children(): widget.destroy()
        for widget in self.cal_frame.winfo_children(): widget.destroy()

        tk.Label(self.header_frame, text=f"{self.year}년 {self.month}월", font=("Arial", 14, "bold")).pack()
        
        days = ["일", "월", "화", "수", "목", "금", "토"]
        for i, day in enumerate(days): tk.Label(self.cal_frame, text=day).grid(row=0, column=i)
        
        cal = calendar.Calendar(firstweekday=6).monthdatescalendar(self.year, self.month)
        for r, week in enumerate(cal):
            for c, date_obj in enumerate(week):
                if date_obj.month == self.month:
                    date_key = f"{self.year}-{self.month}-{date_obj.day}"
                    name = self.engine.assignments.get(date_key, " ")
                    is_duty = self.engine.is_duty_day(self.year, self.month, date_obj.day)
                    
                    btn = tk.Button(self.cal_frame, text=f"{date_obj.day}\n{name}", width=12, height=4,
                                    bg="#e74c3c" if is_duty else "#ecf0f1",
                                    command=lambda d=date_obj.day: self._edit_day(d))
                    btn.grid(row=r+1, column=c)

    def _edit_day(self, day):
        name = simpledialog.askstring("수정", "근무자 이름:", initialvalue=self.engine.assignments.get(f"{self.year}-{self.month}-{day}", ""))
        if name is not None:
            self.engine.assignments[f"{self.year}-{self.month}-{day}"] = name
            self.refresh_calendar()

class App(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("문서 관리 및 근무 통합 시스템")
        self.geometry("900x700")
        self.engine = DutyEngine()
        self.notebook = ttk.Notebook(self)
        self.notebook.pack(expand=True, fill="both")
        self.tab2 = CalendarTab(self.notebook, self.engine)
        self.tab1 = MemberTab(self.notebook, self.engine, self.tab2.refresh_calendar)
        self.notebook.add(self.tab1, text="근무자 관리")
        self.notebook.add(self.tab2, text="휴일 근무 관리")

if __name__ == "__main__":
    App().mainloop()